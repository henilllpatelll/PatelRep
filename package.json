{
  "name": "patelrep",
  "private": true,
  "scripts": {
    "postinstall": "npx patch-package || true",
    "build": "cd apps/web && npm run build",
    "start": "cd apps/web && npm run start",
    "dev:web": "cd apps/web && npm run dev",
    "dev:api": "cd apps/api && .venv/Scripts/python -m uvicorn main:app --reload --port 8000",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:report": "playwright show-report",
    "ab:auth": "powershell -ExecutionPolicy Bypass -File e2e/agent-browser/scripts/auth-setup.ps1",
    "ab:baseline": "powershell -ExecutionPolicy Bypass -File e2e/agent-browser/scripts/visual-baseline.ps1",
    "ab:compare": "powershell -ExecutionPolicy Bypass -File e2e/agent-browser/scripts/visual-compare.ps1",
    "ab:flows": "powershell -ExecutionPolicy Bypass -File e2e/agent-browser/scripts/e2e-flows.ps1",
    "ab:test": "powershell -ExecutionPolicy Bypass -File e2e/agent-browser/scripts/run-all.ps1"
  },
  "dependencies": {
    "patch-package": "^8.0.1"
  },
  "devDependencies": {
    "typescript": "^5.4.0"
  }
}
